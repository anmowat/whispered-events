# Anthropic Claude API
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Airtable
AIRTABLE_API_KEY=your_airtable_personal_access_token_here
AIRTABLE_EVENTS_TABLE=Events
AIRTABLE_PROFILES_TABLE=Users

# Supabase (for matches table)
SUPABASE_URL=your_supabase_project_url
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Resend (for email notifications)
RESEND_API_KEY=your_resend_api_key

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Slack (optional — internal alerts for new user/event, profile updates,
# and host event edits). Set to an Incoming Webhook URL to receive
# notifications. When unset, lib/slack.ts no-ops silently.
SLACK_WEBHOOK_URL=
